extends ./layout

block title
  | Invoice #{invoiceNumber}

block content
  table(role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color: #f3f4f6; font-family: 'Helvetica Neue', Arial, sans-serif;")
    tr
      td(align="center" style="padding: 40px 20px;")
        table(role="presentation" width="600" cellpadding="0" cellspacing="0" style="background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.06);")
          
          // Header
          tr
            td(style="padding: 32px 40px 24px; border-bottom: 1px solid #e5e7eb;")
              table(width="100%" cellpadding="0" cellspacing="0")
                tr
                  td(style="font-size: 24px; font-weight: 800; letter-spacing: 1px; color: #1f4e8a;")
                    | Enorth Logistics
                    span(style="color: #111827;") FREIGHT
                  td(align="right" style="font-size: 13px; color: #6b7280; text-transform: uppercase; letter-spacing: 1px;")
                    | Invoice Notification

          // Body
          tr
            td(style="padding: 32px 40px;")
              p(style="margin: 0 0 20px; font-size: 15px; color: #374151; line-height: 1.6;")
                | Hi 
                strong(style="color: #111827;")= (billTo && billTo.name) || 'there'
                | ,
              p(style="margin: 0 0 24px; font-size: 15px; color: #374151; line-height: 1.6;")
                | Your invoice 
                strong(style="color: #111827;") #{invoiceNumber}
                |  is attached as a PDF. Please review the details below and remit payment by the due date.

              // Summary Box
              table(width="100%" cellpadding="0" cellspacing="0" style="background-color: #f8fafc; border: 1px solid #e5e7eb; border-radius: 6px; margin-bottom: 28px;")
                tr
                  td(style="padding: 20px 24px;")
                    table(width="100%" cellpadding="0" cellspacing="0" style="font-size: 14px; color: #374151;")
                      tr
                        td(style="padding: 6px 0; color: #6b7280; width: 140px;") Invoice Date:
                        td(style="padding: 6px 0; font-weight: 600; color: #111827;") #{invoiceDate}
                      tr
                        td(style="padding: 6px 0; color: #6b7280;") Due Date:
                        td(style="padding: 6px 0; font-weight: 600; color: #c00000;") #{dueDate}
                      tr
                        td(style="padding: 6px 0; color: #6b7280;") Total Due:
                        td(style="padding: 6px 0; font-weight: 700; color: #111827; font-size: 16px;") $#{total.toFixed(2)} #{currency}

              p(style="margin: 0 0 12px; font-size: 14px; color: #4b5563; line-height: 1.6;")
                | If you have any questions about this invoice, please contact our accounts team at 
                a(href="mailto:info@enorthlogistics.com" style="color: #1f4e8a; text-decoration: none; font-weight: 600;") info@enorthlogistics.com
                |  or call 
                strong +1 (437)-889-6500
                | .

          // Footer
          tr
            td(style="padding: 24px 40px; background-color: #f8fafc; border-top: 1px solid #e5e7eb; text-align: center;")
              p(style="margin: 0 0 6px; font-size: 13px; color: #6b7280; font-weight: 600;") Enorth Logistics.
              p(style="margin: 0; font-size: 12px; color: #9ca3af; line-height: 1.5;")
                | 2960 Drew Rd Unit # 156
                br
                | Mississauga, ON L4T 0A5
              p(style="margin: 12px 0 0; font-size: 11px; color: #9ca3af;") Thank you for your business.